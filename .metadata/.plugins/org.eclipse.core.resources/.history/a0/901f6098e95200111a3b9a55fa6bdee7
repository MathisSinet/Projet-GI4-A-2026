package flowly.geometry;

public class DelaunayTriangle {
    private VoronoiSite[] vertices = new VoronoiSite[3];

    public DelaunayTriangle(VoronoiSite s1, VoronoiSite s2, VoronoiSite s3) {
        this.vertices[0] = s1;
        this.vertices[1] = s2;
        this.vertices[2] = s3;
    }

    public VoronoiSite[] getVertices() {
        return vertices;
    }
}