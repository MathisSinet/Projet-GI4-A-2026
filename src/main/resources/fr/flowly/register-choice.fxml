<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="874.0" prefWidth="400.0" xmlns:fx="http://javafx.com/fxml"
           fx:controller="fr.flowly.MainController">
    
    <stylesheets>
        <URL value="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&amp;display=swap" />
        <URL value="@css/global.css" />
        <URL value="@css/login.css" />
    </stylesheets>

    <ImageView fitHeight="874.0" fitWidth="400.0" pickOnBounds="true" preserveRatio="false">
        <image>
            <Image url="@login.png" />
        </image>
    </ImageView>

    <BorderPane>
        <padding>
            <Insets bottom="60.0" left="25.0" right="25.0" top="60.0"/>
        </padding>

        <center>
        </center>

        <bottom>
            <VBox alignment="CENTER" spacing="20.0">
                
                <Label text="Join Flowly as..." styleClass="form-heading"/>
                
                <HBox styleClass="segmented-bar" alignment="CENTER">
                    <Button text="Tourist" fx:id="touristButton" styleClass="segmented-button, left-button"/>
                    <Button text="Manager" fx:id="managerButton" styleClass="segmented-button, right-button"/>
                </HBox>
                
                <Button text="Back to Log In" styleClass="link-button"/>
                
            </VBox>
        </bottom>
    </BorderPane>
</StackPane>