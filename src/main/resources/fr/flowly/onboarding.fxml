<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>  
<?import javafx.scene.control.Button?>  
<?import javafx.scene.image.Image?>  
<?import javafx.scene.image.ImageView?>  
<?import javafx.scene.control.Label?>  
<?import javafx.scene.layout.BorderPane?>  
<?import javafx.scene.layout.StackPane?>  
<?import javafx.scene.layout.VBox?>  

<StackPane prefHeight="874.0" prefWidth="400.0" xmlns:fx="http://javafx.com/fxml"  
           fx:controller="fr.flowly.MainController">  
      
    <stylesheets>  
        <URL value="https://fonts.googleapis.com/css2?family=Poppins:wght@700&amp;display=swap" />  
        <URL value="@css/global.css" />
        <URL value="@css/onboarding.css" />
    </stylesheets>  

    <ImageView fitHeight="874.0" fitWidth="400.0" pickOnBounds="true" preserveRatio="false">  
        <image>  
            <Image url="@background.png" />  
        </image>  
    </ImageView>  

    <BorderPane>  
        <padding>  
            <Insets bottom="50.0" left="25.0" right="25.0" top="60.0"/>  
        </padding>  

        <center>  
        </center>  

        <bottom>  
            <VBox alignment="CENTER" spacing="44.0">  
                  
                <Label fx:id="welcomeText" text="Escape the crowd" styleClass="welcome-title"/>  
                  
                <Button text="DISCOVER" onAction="#onViewButtonClick" styleClass="discover-button"/>  
            </VBox>  
        </bottom>  
    </BorderPane>  
      
</StackPane>