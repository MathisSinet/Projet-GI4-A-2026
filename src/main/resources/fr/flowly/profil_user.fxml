<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="874.0" prefWidth="400.0" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="fr.flowly.MainController">
    
    <stylesheets>
        <URL value="@css/global.css" />
        <URL value="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&amp;display=swap" />
        <URL value="@css/profil_user.css" />
    </stylesheets>

    <BorderPane style="-fx-background-color: #121212;">
        <padding>
            <Insets top="40.0" right="25.0" bottom="20.0" left="25.0"/>
        </padding>

        <top>
            <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-padding: 0 0 30 0;">
                <Label text=" " style="-fx-font-size: 45px; -fx-text-fill: #8e8e93; -fx-background-color: rgba(255,255,255,0.05); -fx-padding: 10; -fx-background-radius: 50;"/>
                <TextField promptText="PseudoMagnifique" styleClass="user-input-main" HBox.hgrow="ALWAYS" prefHeight="55.0"/>
            </HBox>
        </top>

        <center>
            <VBox spacing="30.0" alignment="TOP_CENTER">
                
                <VBox spacing="0.0" alignment="TOP_CENTER" styleClass="accordion-section">
                    <Button text="Historique" styleClass="btn-section-header" prefWidth="350.0" prefHeight="45.0"/>
                    <Button text="Lieu 1" styleClass="btn-section-item" prefWidth="330.0" prefHeight="40.0"/>
                    <Button text="Lieu 2" styleClass="btn-section-item" prefWidth="330.0" prefHeight="40.0"/>
                </VBox>

                <VBox spacing="0.0" alignment="TOP_CENTER" styleClass="accordion-section">
                    <Button text="Favoris" styleClass="btn-section-header" prefWidth="350.0" prefHeight="45.0"/>
                    <Button text="Lieu 3" styleClass="btn-section-item" prefWidth="330.0" prefHeight="40.0"/>
                    <Button text="Lieu 4" styleClass="btn-section-item" prefWidth="330.0" prefHeight="40.0"/>
                </VBox>

                <VBox alignment="CENTER" style="-fx-padding: 60 0 0 0;" VBox.vgrow="ALWAYS">
                    <Label text="PROFIL" styleClass="user-footer-title"/>
                </VBox>
            </VBox>
        </center>

        <bottom>
            <VBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                <HBox spacing="25.0" styleClass="nav-bar">
                    <Button contentDisplay="TOP" text="Home" styleClass="nav-button"/>
                    <Button contentDisplay="TOP" text="Explorer" styleClass="nav-button"/>
                    <Button contentDisplay="TOP" text="Profil" styleClass="nav-button, nav-active"/>
                </HBox>
            </VBox>
        </bottom>
    </BorderPane>
</StackPane>