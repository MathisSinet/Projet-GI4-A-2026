<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?> <?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="874.0" prefWidth="400.0" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="fr.flowly.MainController">
    
    <stylesheets>
		<URL value="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&amp;display=swap" />
        <URL value="@css/modify.css" />
    </stylesheets>

    <BorderPane style="-fx-background-color: #121212;">
        <padding>
            <Insets top="50.0" right="25.0" bottom="50.0" left="25.0"/>
        </padding>

        <top>
            <VBox alignment="CENTER" style="-fx-padding: 0 0 20 0;">
                <Label text="MODIFIER MON LIEU" styleClass="filter-heading"/>
            </VBox>
        </top>

        <center>
            <VBox spacing="25.0" alignment="TOP_LEFT">
                
                <Label text="DENSITÉ DE LA FOULE" styleClass="filter-section-title"/>
                <HBox spacing="10.0" alignment="CENTER">
                    <Button text="CALME" styleClass="btn-calme" prefWidth="110" prefHeight="45"/>
                    <Button text="NORMAL" styleClass="btn-normal" prefWidth="110" prefHeight="45"/>
                    <Button text="BONDÉ" styleClass="btn-bonde" prefWidth="110" prefHeight="45"/>
                </HBox>

                <Label text="CONSULTATION DES UTILISATEURS" styleClass="filter-section-title"/>
                <HBox alignment="CENTER_LEFT">
                    <Button text="10 000" styleClass="btn-consultation" prefWidth="110" prefHeight="45"/>
                </HBox>

                <Label text="HORAIRE" styleClass="filter-section-title"/>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <Button text="9H00 - 20H00" styleClass="btn-horaire-val" prefWidth="180" prefHeight="50"/>
                    <Button text="MODIFIER" styleClass="btn-modifier-gray" prefWidth="120" prefHeight="50"/>
                </HBox>

                <Label text="DESCRIPTION" styleClass="filter-section-title"/>
                <VBox alignment="CENTER_LEFT">
                    <Button text="MODIFIER" styleClass="action-button" prefWidth="350" prefHeight="50"/>
                </VBox>

            </VBox>
        </center>

        <bottom>
        <VBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                <HBox spacing="25.0" styleClass="nav-bar">
                    <Button contentDisplay="TOP" text="Home" styleClass="nav-button"/>
                    <Button contentDisplay="TOP" text="Modifier" styleClass="nav-button, nav-active"/>
                    <Button contentDisplay="TOP" text="Profile" styleClass="nav-button"/>
                </HBox>
            </VBox>
            
        </bottom>
    </BorderPane>
</StackPane>